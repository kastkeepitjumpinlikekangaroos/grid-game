# Example environment variables for grid-game telemetry.
#
# Copy to .env (gitignored) and source before running the server:
#
#   source ops/observability/.env
#   bazel run //src/main/scala/com/gridgame/server:server
#

# --- Required-ish (have safe defaults in Telemetry.init) ---
export OTEL_SERVICE_NAME=grid-game-server
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# --- Optional ---
# How often to flush metrics (ms)
export OTEL_METRIC_EXPORT_INTERVAL=10000
# Tag every signal
export OTEL_RESOURCE_ATTRIBUTES="service.version=dev,deployment.environment=dev,host.name=$(hostname)"
# Turn telemetry off entirely
# export OTEL_SDK_DISABLED=true

# --- Client (only when you want client telemetry too) ---
# export GRIDGAME_TELEMETRY=1
